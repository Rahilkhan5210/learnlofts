{
  "name": "learnloft",
  "version": "1.0.0",
  "description": "A platform for selling professional certifications and courses",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "keywords": [
    "certifications",
    "courses",
    "education",
    "web-development",
    "mern-stack"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
} 